# Copy to .env.local for local Docker/Compose runtime configuration.
# Never commit real provider keys.

# Optional daemon protection token for HTTP calls from outside the daemon network namespace.
ORDO_DAEMON_ACCESS_TOKEN=

# Provider keys recognized by the daemon provider catalog and guarded live eval runner.
ANTHROPIC_API_KEY=
API__ANTHROPIC_API_KEY=
OPENAI_API_KEY=
API__OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Backward-compatible local DeepSeek key spelling recognized by the daemon.
deepseek=

# Optional model/provider preferences for local experiments.
ANTHROPIC_MODEL=
ORDO_LIVE_LLM_PROVIDER=openai
ORDO_LIVE_LLM_MODEL=
ORDO_LIVE_LLM_MAX_CASES=1
ORDO_LIVE_LLM_BUDGET_USD=0.01

# Live network guards stay disabled unless explicitly set to 1 for a manual run.
ORDO_LIVE_LLM_EVALS=0
ORDO_LIVE_LLM_ALLOW_NETWORK=0

# Future governed outbound communication configuration. No real email is sent by default.
TRANSACTIONAL_EMAIL_PROVIDER=
